# syntax=docker/dockerfile:1.7
# Standalone DCC/Razor/Pyzor backend for rspamd — a single static Go binary on a
# distroless base. This image runs NO rspamd. It exposes one authenticated HTTP
# endpoint (:8077) that rspamd's dcc_razor_pyzor.lua plugin (in a SEPARATE
# container) queries.
#   * gozer — speaks Razor (gazor), Pyzor (gyzor) and DCC (gdcc) ALL IN-PROCESS.
#     It replaces the old Python implementation that forked the perl razor-*,
#     python pyzor and dccproc CLIs per message; there are now NO per-message
#     forks and NO supervisor — gozer is the entrypoint, running as nonroot.
#
# Nothing else is installed: no razor/pyzor/perl/python, no dcc package
# (dccproc/cdcc, set-UID dcc, /var/dcc), no s6-overlay, no shell. gazor, gyzor
# and gdcc are linked into the binary, which talks to the networks directly.
ARG GO_VERSION=1.24

# --- build stage: compile the static gozer binary (fully offline: deps are
# vendored, so no module proxy / git fetch is needed) ---------------------------
# gozer source comes from the docker/gozer submodule (its own repo,
# github.com/eilandert/gozer). Build context is docker/, so it sits at gozer/.
FROM golang:${GO_VERSION}-alpine AS build
WORKDIR /src
COPY gozer/go.mod gozer/go.sum ./
COPY gozer/vendor/ ./vendor/
COPY gozer/cmd/ ./cmd/
COPY gozer/internal/ ./internal/
ARG GOZER_VERSION=dev
RUN CGO_ENABLED=0 go build -mod=vendor -trimpath \
      -ldflags="-s -w -X main.version=${GOZER_VERSION}" \
      -o /out/gozer ./cmd/gozer

# --- runtime stage: distroless static, nonroot, no shell ------------------------
# All three networks are linked into the single static gozer binary, so the
# runtime needs nothing but the binary and CA roots (for the razor/pyzor TLS
# handshakes; DCC is plain UDP). No Debian base, no s6, no apt, no shell.
FROM gcr.io/distroless/static-debian12:nonroot
LABEL org.opencontainers.image.authors="eilandert"
LABEL org.opencontainers.image.source="https://github.com/eilandert/rspamd-dcc-razor-pyzor"
LABEL maintainer="Thijs Eilander <eilander@myguard.nl>"

# gozer reads ALL config from the environment (GOZER_*, DCC_*, RAZOR_*, PYZOR_*).
# The image has no writable state: /check works anonymously; for /report supply
# RAZOR_USER/RAZOR_PASS (or their _FILE forms) — obtain an anonymous razor
# credential with `gozer razor-register`.
ENV GOZER_HOST=0.0.0.0 \
    GOZER_PORT=8077

COPY --from=build /out/gozer /usr/local/bin/gozer

# gozer HTTP endpoint queried by the external rspamd plugin. Reachable on the
# docker network only — do NOT publish to the host (see docker-compose).
EXPOSE 8077

# distroless ships no shell or curl; gozer probes its own /health endpoint.
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD ["/usr/local/bin/gozer", "health"]

USER nonroot
STOPSIGNAL SIGTERM
ENTRYPOINT ["/usr/local/bin/gozer", "serve"]
