# syntax=docker/dockerfile:1.7
# rspamd + DCC/Razor/Pyzor collaborative filters, supervised by s6-overlay.
#   * rspamd            — the scanner (loads dcc_razor_pyzor.lua)
#   * spamcheck_shim    — HTTP wrapper around the three CLIs (s6 longrun)
#   * dccifd            — DCC interface daemon (s6 longrun)
#   * razor / pyzor     — per-message CLIs invoked by the shim
FROM eilandert/debian-base:stable
LABEL org.opencontainers.image.authors="eilandert"
LABEL org.opencontainers.image.source="https://github.com/eilandert/rspamd-dcc-razor-pyzor"
LABEL maintainer="Thijs Eilander <eilander@myguard.nl>"

ENV DEBIAN_FRONTEND="noninteractive" \
    DIST=trixie \
    RAZORHOME=/var/lib/razor \
    PYZOR_HOME=/var/lib/pyzor \
    S6_KEEP_ENV=1 \
    S6_CMD_WAIT_FOR_SERVICES_MAXTIME=0 \
    S6_BEHAVIOUR_IF_STAGE2_FAILS=2

ARG S6_OVERLAY_VERSION=3.2.1.0
ADD https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz /tmp/
ADD https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-x86_64.tar.xz /tmp/

# DCC has no Debian package (licence). Pin a known source tarball.
ARG DCC_VERSION=2.3.168

RUN set -ex; \
    apt-get -y update; \
    apt-get --no-install-recommends -y install ca-certificates curl xz-utils; \
    # rspamd apt repo (same source the rspamd-git image uses)
    echo "deb [arch=amd64 trusted=yes] http://rspamd.com/apt-stable/ $DIST main" \
      > /etc/apt/sources.list.d/rspamd.list; \
    apt-get -y update; \
    apt-get --no-install-recommends -y install \
      rspamd \
      python3 \
      pyzor \
      gcc make libc6-dev; \
    # razor (package name drifted between releases): try both
    ( apt-get --no-install-recommends -y install razor-agents \
      || apt-get --no-install-recommends -y install razor ) || true; \
    # s6-overlay
    tar -C / -Jxpf /tmp/s6-overlay-noarch.tar.xz; \
    tar -C / -Jxpf /tmp/s6-overlay-x86_64.tar.xz; \
    rm -f /tmp/s6-overlay-*.tar.xz; \
    # DCC: dedicated user + build from source -> /var/dcc
    adduser --system --group --no-create-home --home /var/dcc dcc; \
    cd /tmp; \
    curl -fsSL "https://www.dcc-servers.net/dcc/source/old/dcc-${DCC_VERSION}.tar.Z" -o dcc.tar.Z \
      || curl -fsSL "https://www.dcc-servers.net/dcc/source/dcc.tar.Z" -o dcc.tar.Z; \
    tar -xf dcc.tar.Z; \
    cd dcc-*; \
    ./configure --disable-dccm --with-uid=dcc --homedir=/var/dcc; \
    make install; \
    cd /; rm -rf /tmp/dcc*; \
    chown -R dcc:dcc /var/dcc; \
    # rspamd container defaults (console logging, controller bind, no pidfile)
    mkdir -p /etc/rspamd/override.d; \
    mv /etc/rspamd /etc/rspamd.orig; \
    mkdir -p /etc/rspamd /var/log/rspamd /var/lib/rspamd /var/run/rspamd \
             "${RAZORHOME}" "${PYZOR_HOME}"; \
    # drop build toolchain to keep the image lean
    apt-get -y purge gcc make libc6-dev; \
    apt-get -y autoremove; \
    apt-get -y clean autoclean; \
    rm -rf /var/lib/apt/lists/* /var/cache/apt /usr/local/share/man

# Project payload (plugin + shim + s6 service tree).
COPY rspamd/ /opt/drp/rspamd/
COPY shim/   /opt/drp/shim/
COPY root/   /
COPY --chmod=0755 healthcheck.sh /healthcheck.sh

RUN set -ex; \
    chmod 0755 /opt/drp/shim/spamcheck_shim.py \
               /etc/s6-overlay/scripts/init-bootstrap.sh \
               /etc/s6-overlay/s6-rc.d/dccifd/run \
               /etc/s6-overlay/s6-rc.d/shim/run \
               /etc/s6-overlay/s6-rc.d/rspamd/run

VOLUME [ "/var/lib/rspamd" ]
# rspamd: 11332 normal, 11333 controller (legacy), 11334 controller/web
EXPOSE 11332 11333 11334

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD /healthcheck.sh || exit 1

STOPSIGNAL SIGTERM
ENTRYPOINT ["/init"]
CMD []
